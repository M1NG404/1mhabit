<view class="focus-page">
  <view class="focus-top">
    <button bindtap="cancel">取消</button>
    <button bindtap="complete">完成并记录</button>
  </view>

  <view class="timer-center">
    <view class="phase">1 分钟启动</view>
    <view class="ring">
      <view class="time">{{timeText}}</view>
    </view>
    <view class="focus-title">{{habit.title}}</view>
    <view class="focus-copy">你只需要对这一分钟负责。结束后，系统会邀请你进入 5 分钟沉浸。</view>
  </view>

  <view class="timer-actions">
    <button class="primary light" bindtap="goFocus">进入 5 分钟</button>
    <button class="secondary dark" bindtap="togglePause">{{running ? '暂停' : '继续'}}</button>
  </view>
</view>
