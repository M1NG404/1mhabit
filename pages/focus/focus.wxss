.focus-page {
  min-height: 100vh;
  padding: 72rpx 32rpx 48rpx;
  display: grid;
  grid-template-rows: auto 1fr auto;
  color: #ffffff;
  background: linear-gradient(180deg, #1a2b57 0%, #101820 42%, #080b10 100%);
}

.focus-top {
  display: flex;
  justify-content: space-between;
}

.focus-top button {
  color: rgba(255, 255, 255, 0.78);
  background: transparent;
  font-size: 28rpx;
  font-weight: 800;
}

.timer-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.phase {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  font-weight: 800;
}

.time {
  margin: 78rpx 0 54rpx;
  font-size: 126rpx;
  font-weight: 850;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.focus-title {
  font-size: 34rpx;
  font-weight: 800;
}

.focus-copy {
  width: 560rpx;
  margin-top: 22rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 28rpx;
  line-height: 1.5;
}

.timer-actions {
  display: grid;
  gap: 18rpx;
}

.light {
  color: #101820;
  background: #ffffff;
  box-shadow: none;
}

.dark {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
}
