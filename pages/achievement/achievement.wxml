<view class="page">
  <view class="topbar">
    <view>
      <view class="title">成就</view>
      <view class="subtitle">正反馈要轻，不制造失败压力</view>
    </view>
  </view>

  <view class="card hero-card">
    <view class="hero-metric">{{total}} 次</view>
    <view class="hero-copy">你已经完成了 {{total}} 个小动作和启动阶段。</view>
  </view>

  <view class="section-head">
    <view class="section-title">已获得</view>
    <view class="section-extra">{{achievements.length}} 枚</view>
  </view>

  <view class="badge-list" wx:if="{{achievements.length}}">
    <view class="card badge-card" wx:for="{{achievements}}" wx:key="id">
      <view class="badge">{{index + 1}}</view>
      <view>
        <view class="badge-title">{{item.title}}</view>
        <view class="badge-copy">{{item.description}}</view>
      </view>
    </view>
  </view>

  <view class="card soft-banner" wx:else>
    <text class="soft-title">还没有成就</text>
    <view class="soft-copy">完成 3 次小动作后，将获得第一枚徽章。</view>
  </view>
</view>
