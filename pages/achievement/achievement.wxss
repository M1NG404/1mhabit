.badge-list {
  display: grid;
  gap: 22rpx;
}

.badge-card {
  display: grid;
  grid-template-columns: 104rpx 1fr;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
}

.badge {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 159, 10, 0.18);
  color: #a46600;
  font-size: 34rpx;
  font-weight: 900;
}

.badge-title {
  font-size: 32rpx;
  font-weight: 800;
}

.badge-copy {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 25rpx;
}
